{
  "name": "ontouml-schema",
  "version": "1.0.1",
  "description": "This package provides a JSON Schema representation ontologies based on the OntoUML Metamodel. This serialization models in JSON is intended to support the exchange of models over HTTP requests.",
  "main": "src/index.js",
  "license": "Apache-2.0",
  "files": [
    "dist/ontouml-schema.json",
    "src/index.js",
    "src/ontouml-schema.yaml"
  ],
  "scripts": {
    "test": "npx ajv compile --spec=draft2020 -s dist/ontouml-schema.json -c ajv-formats",
    "generate": "npx yaml2json -s src/ontouml-schema.yaml && mv src/ontouml-schema.json dist/ontouml-schema.json && npx prettier --write dist/ontouml-schema.json",
    "draftBump": "npm version prerelease --preid=draft",
    "prepublishOnly": "npm-run-all -s generate test",
    "prepare": "husky install"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OntoUML/ontouml-schema.git"
  },
  "keywords": [],
  "author": "",
  "bugs": {
    "url": "https://github.com/OntoUML/ontouml-schema/issues"
  },
  "homepage": "https://github.com/OntoUML/ontouml-schema/",
  "devDependencies": {
    "ajv": "^8.12.0",
    "ajv-cli": "^5.0.0",
    "ajv-formats": "^2.1.1",
    "husky": "^8.0.3",
    "jest": "^29.6.2",
    "lint-staged": "^14.0.1",
    "npm-run-all": "^4.1.5",
    "onchange": "^7.1.0",
    "prettier": "3.0.2",
    "yamljs": "^0.3.0"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  }
}
